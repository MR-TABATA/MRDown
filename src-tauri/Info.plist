<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- 既定では Tauri は CFBundleDevelopmentRegion=English のみを出力するため、
       macOS がアプリを英語専用とみなし、印刷・保存パネルなどシステム提供の UI が
       常に英語になる。対応ロケールを宣言してシステム言語に追従させる。 -->
  <key>CFBundleLocalizations</key>
  <array>
    <string>en</string>
    <string>ja</string>
  </array>
</dict>
</plist>
